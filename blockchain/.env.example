# Server
PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=crypto_orders

# Wallet addresses (USDC/USDT on Ethereum use the same address as ETH)
WALLET_ETH=0xD49426272cb4d3a4E14e5110Fa30c3e017e86e4d
WALLET_USDC=0xD49426272cb4d3a4E14e5110Fa30c3e017e86e4d
WALLET_USDT=0xD49426272cb4d3a4E14e5110Fa30c3e017e86e4d
WALLET_SOL=vadVCNpisfBNeC7GkcoQYojUL1a5bgim4Rue1hoHLRN
WALLET_BTC=bc1qpdmvlg6yq4s5en6y3k24qxtu2nv5fvfz5680sa

# Etherscan (Ethereum + ERC-20 tokens)
ETHERSCAN_API_KEY=your_etherscan_api_key

# Email (Gmail app password or SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com
ADMIN_EMAIL=your-admin-email@gmail.com

# Payment monitor
MONITOR_INTERVAL_MS=30000
AMOUNT_TOLERANCE=0.01

# Crypto checkout surcharge on subtotal + shipping (default 3%)
CRYPTO_FEE_PERCENT=3

# Set this in cart.html + crypto-pay.html meta when deployed:
# <meta name="nt-crypto-checkout-url" content="https://your-checkout-server.com">

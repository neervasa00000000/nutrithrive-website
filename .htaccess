RedirectMatch 301 ^/about-us/?$ /pages/about/about.html
RedirectMatch 301 ^/reviews/?$ /products/
RedirectMatch 301 ^/recipes/high-protein-smoothies\.pdf$ https://nutrithrive.com.au/
